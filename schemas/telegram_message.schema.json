{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Telegram Message",
  "type": "object",
  "required": [
    "service",
    "event",
    "chat_id",
    "message_id",
    "sender_id",
    "is_bot",
    "sender_username",
    "sender_fullname",
    "text",
    "text_html",
    "date",
    "is_reply",
    "reply_to",
    "has_media",
    "media",
    "out",
    "links"
  ],
  "properties": {
    "service": {
      "type": "string"
    },
    "event": {
      "type": "string"
    },
    "chat_id": {
      "type": "integer"
    },
    "message_id": {
      "type": "integer"
    },
    "sender_id": {
      "type": "integer"
    },
    "is_bot": {
      "type": "boolean"
    },
    "sender_username": {
      "type": ["string", "null"]
    },
    "sender_fullname": {
      "type": ["string", "null"]
    },
    "text": {
      "type": ["string", "null"]
    },
    "text_html": {
      "type": ["string", "null"]
    },
    "date": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "is_reply": {
      "type": "boolean"
    },
    "reply_to": {
      "type": ["object", "null"],
      "required": [
        "message_id",
        "sender_id",
        "sender_username",
        "sender_fullname",
        "text",
        "text_html",
        "links"
      ],
      "properties": {
        "message_id": {
          "type": "integer"
        },
        "sender_id": {
          "type": "integer"
        },
        "sender_username": {
          "type": ["string", "null"]
        },
        "sender_fullname": {
          "type": ["string", "null"]
        },
        "text": {
          "type": ["string", "null"]
        },
        "text_html": {
          "type": ["string", "null"]
        },
        "links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "has_media": {
      "type": "boolean"
    },
    "media": {
      "type": ["object", "null"]
    },
    "out": {
      "type": "boolean"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
